// Test: For loops
// Tests for loop type checking

fn test_c_style_for() {
    let mut sum = 0;
    for (let mut i = 0; i < 10; i = i + 1) {
        sum = sum + i;
    }
    return sum;
}

fn test_range_for() {
    let mut total = 0;
    for (let i in 0..10) {
        total = total + i;
    }
    return total;
}
