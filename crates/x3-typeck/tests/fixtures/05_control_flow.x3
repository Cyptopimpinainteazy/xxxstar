// Test: Control flow type checking
// Tests if/else, while, and loop statements

fn test_if() {
    let cond = true;
    if (cond) {
        let x = 1;
    }
    return 0;
}

fn test_if_else() {
    let flag = false;
    if (flag) {
        return 1;
    } else {
        return 0;
    }
}

fn test_while() {
    let mut i = 0;
    while (i < 10) {
        i = i + 1;
    }
    return i;
}

fn test_loop() {
    let mut count = 0;
    loop {
        count = count + 1;
        if (count > 5) {
            break;
        }
    }
    return count;
}
