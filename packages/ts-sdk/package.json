{
  "name": "@x3-chain/ts-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for X3 Chain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src",
    "docs/root/README.md"
  ],
  "keywords": [
    "x3-chain",
    "blockchain",
    "sdk",
    "typescript",
    "substrate",
    "polkadot"
  ],
  "author": "X3 Chain Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@polkadot/api": "^14.0.1",
    "@polkadot/types": "^14.0.1",
    "@polkadot/util": "^13.0.0",
    "@polkadot/util-crypto": "^13.0.0",
    "@solana/web3.js": "^1.87.0",
    "axios": "^1.16.0",
    "ethers": "^6.8.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/x3-chain/ts-sdk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
