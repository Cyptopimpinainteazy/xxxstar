{
  "compilation": {
    "platform": "foundry"
  },
  "fuzzing": {
    "workers": 16,
    "workerDatabaseEntryLimit": 500000,
    "timeout": 14400,
    "testLimit": 1000000,
    "callSequenceLength": 100,
    "corpusDirectory": "tests/security/medusa-corpus",
    "coverageEnabled": true,
    "targetContracts": [],
    "targetContractsBalances": [],
    "predeployedContracts": {}
  },
  "testing": {
    "stopOnFailedTest": false,
    "stopOnFailedContractMatching": false,
    "testAllContracts": false,
    "traceAll": false,
    "propertyTesting": {
      "enabled": true,
      "testPrefixes": ["fuzz_", "medusa_", "property_"]
    },
    "optimizationTesting": {
      "enabled": false
    },
    "assertionTesting": {
      "enabled": true,
      "panicCodeConfig": {
        "failOnCompilerInsertedPanic": true,
        "failOnAssertion": true,
        "failOnArithmeticUnderflow": true,
        "failOnDivisionByZero": true,
        "failOnEnumTypeConversionOutOfBounds": true,
        "failOnIncorrectStorageAccess": true,
        "failOnPopEmptyArray": true,
        "failOnOutOfBoundsArrayAccess": true,
        "failOnAllocateTooMuchMemory": true,
        "failOnCallUninitializedVariable": true
      }
    }
  },
  "logging": {
    "level": "info",
    "logDirectory": "tests/security/medusa-logs"
  }
}
