# X3 Chain SDK Environment Configuration
# Copy this file to .env and configure for your environment

# Network Configuration
# Options: mainnet, testnet, local
X3_NETWORK=local

# RPC Endpoint Configuration
# Override the default endpoint for the selected network
# X3_RPC_ENDPOINT=wss://rpc.x3chain.io:9944

# Connection Settings
# Enable automatic reconnection on disconnect
X3_AUTO_RECONNECT=true

# Maximum number of reconnection attempts before giving up
X3_RECONNECT_MAX=5

# Initial delay between reconnection attempts (milliseconds)
# Will be multiplied by 2 for each subsequent attempt (exponential backoff)
X3_RECONNECT_DELAY=1000

# Request timeout in milliseconds
X3_TIMEOUT=30000

# Enable debug logging
X3_DEBUG=false
