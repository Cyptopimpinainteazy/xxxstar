    "events": "^3.3.0",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/sinon": "^10.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "chai": "4.3.7",
    "ecpair": "^2.1.0",
    "eslint": "^8.0.0",
    "mocha": "^10.2.0",
    "sinon": "^15.0.0",
    "supertest": "^7.0.0",
    "tiny-secp256k1": "^2.2.3",
