    "start": "ts-node src/index.ts",
    "serve": "ts-node src/http-server.ts"
  },
  "dependencies": {
    "bip68": "^1.0.1",
    "bitcoinjs-lib": "^7.0.0",
    "body-parser": "^1.20.2",
