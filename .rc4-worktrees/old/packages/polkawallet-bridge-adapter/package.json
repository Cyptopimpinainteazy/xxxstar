{
  "name": "@x3-chain/polkawallet-bridge-adapter",
  "version": "0.1.0",
  "description": "Polkawallet bridge adapter for X3 Chain x3chain — enables XCM and atomic cross-chain transfers through the Polkawallet Bridge SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@polkadot/api": "^14.0.1",
    "@polkadot/types": "^14.0.1",
    "@polkadot/util": "^13.0.0",
    "@polkadot/util-crypto": "^13.0.0"
  },
  "peerDependencies": {
    "@polkawallet/bridge": "^0.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist/",
    "src/",
    "docs/root/README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/x3-chain/x3-chain",
    "directory": "packages/polkawallet-bridge-adapter"
  }
}
