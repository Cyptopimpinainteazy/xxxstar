# X3 Chain Jury Service Configuration
# Source this file in jury.service or set manually in /etc/x3/jury/jury.env
# See: systemctl cat jury.service

# ============================================================
# Database Configuration
# ============================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://jury_admin:jury_secure_password_change_me@localhost:5432/jury_audit
SQLALCHEMY_DATABASE_URL=postgresql://jury_admin:jury_secure_password_change_me@localhost:5432/jury_audit

# ============================================================
# Redis Configuration (optional, for clustering/caching)
# ============================================================
REDIS_URL=redis://:redis_secure_password_change_me@localhost:6379/0

# ============================================================
# Jury Service Configuration
# ============================================================
# Network binding
JURY_API_HOST=0.0.0.0
JURY_API_PORT=8000

# Logging
JURY_LOG_LEVEL=INFO

# Jury session timeouts (in seconds)
JURY_COMMIT_DEADLINE_SECONDS=300
JURY_REVEAL_DEADLINE_SECONDS=600

# Jury composition rules
JURY_MIN_MEMBERS=3
JURY_MAX_MEMBERS=21
JURY_QUORUM_THRESHOLD=0.66
JURY_SECTION_DIVERSITY_CAP=0.75

# ============================================================
# On-Chain Integration
# ============================================================
# RPC endpoint for on-chain anchoring (stub for Phase 4 implementation)
ONCHAIN_RPC_URL=http://localhost:9944
ONCHAIN_ANCHOR_ENABLED=false
ONCHAIN_CHAIN_ID=x3-chain

# ============================================================
# GPU Configuration
# ============================================================
GPU_ENABLED=false
CUDA_VISIBLE_DEVICES=0

# ============================================================
# Telemetry & Observability
# ============================================================
# OpenTelemetry tracing
TELEMETRY_ENABLED=true
TELEMETRY_ENDPOINT=http://localhost:4317
TELEMETRY_SERVICE_NAME=jury-service

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=8001
METRICS_PATH=/metrics

# ============================================================
# Security
# ============================================================
# API key for securing sensitive endpoints (set in jury.local.env)
JURY_API_KEY_REQUIRED=true
# JURY_API_KEY=your-secret-key-here  # Set in jury.local.env, not here!

# CORS configuration
JURY_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
JURY_CORS_ALLOW_CREDENTIALS=true

# ============================================================
# Performance Tuning
# ============================================================
# Maximum concurrent jury sessions
MAX_CONCURRENT_SESSIONS=100

# Database connection pool settings
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10

# Redis connection pool settings (if using)
REDIS_POOL_SIZE=10

# ============================================================
# Development/Advanced
# ============================================================
# Debug mode (disable in production)
DEBUG=false

# Verbose logging for troubleshooting
VERBOSE=false

# Audit log retention (days before archival)
AUDIT_LOG_RETENTION_DAYS=90

# Enable audit log archival to cold storage
AUDIT_ARCHIVE_ENABLED=false
AUDIT_ARCHIVE_PATH=/var/archive/jury/audit

# Feature flags
FEATURE_NEW_COMMIT_REVEAL=true
FEATURE_ASYNC_ANCHORING=false
