# Inferstructor Dashboard environment template

# Core API endpoints
VITE_X3_API_URL=https://api.x3star.net
VITE_REGISTRY_URL=https://api.x3star.net
VITE_BRIDGE_URL=https://api.x3star.net
VITE_RPC_PROXY_URL=https://api.x3star.net
VITE_ADMIN_URL=https://api.x3star.net
VITE_CHAIN_DB_URL=https://api.x3star.net

# GPU lane configuration
# Base URL used to construct defaults: :9001/health, :9002/health, :9003/health
VITE_GPU_LANE_BASE=http://localhost

# Optional explicit per-lane overrides
# VITE_GPU_LANE_1_URL=http://localhost:9001/health
# VITE_GPU_LANE_2_URL=http://localhost:9002/health
# VITE_GPU_LANE_3_URL=http://localhost:9003/health

# Local admin password (development only)
ADMIN_PASSWORD=change-me
