# Botchain Tri-VM Genesis Configuration
# Copy this to .env and customize

# === Network Configuration ===
HARDHAT_NETWORK=localhost
HARDHAT_RPC_URL=http://localhost:8545
CHAIN_ID=31337

# === IPFS Configuration ===
IPFS_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080

# === Bitcoin Configuration (Regtest) ===
BITCOIN_RPC_URL=http://localhost:18443
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASS=bitcoin
BITCOIN_NETWORK=regtest

# === Compiler Configuration ===
COMPILER_KEY_PATH=./compiler/key.pem
COMPILER_VERSION=botchain-compiler-1

# === Checker Service ===
CHECKER_HOST=0.0.0.0
CHECKER_PORT=8001
CHECKER_MAX_FILE_SIZE=16777216

# === Trainer Configuration ===
TRAINER_MODEL_TYPE=toy-deterministic
TRAINER_MAX_EPOCHS=10
TRAINER_LEARNING_RATE=0.001

# === Contract Addresses (set after deployment) ===
BOT_TOKEN_ADDRESS=
MARRIAGE_LICENSE_ADDRESS=
ATOMIC_SWAP_ADDRESS=
SIMPLE_DEX_ADDRESS=

# === Account Keys (for testing only - NEVER use in production) ===
# These are Hardhat's default test accounts
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ALICE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
BOB_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# === Simulation Parameters ===
MARRIAGE_FEE=100000000000000000000
INITIAL_BOT_SUPPLY=1000000000000000000000000
HTLC_TIMELOCK_BLOCKS=48

# === Logging ===
LOG_LEVEL=INFO
ENABLE_DEBUG_LOGS=false
