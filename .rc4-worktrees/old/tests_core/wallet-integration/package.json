{
  "name": "x3-chain-wallet-integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for MetaMask and Phantom wallet connectivity",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:metamask": "jest tests/metamask",
    "test:phantom": "jest tests/phantom",
    "test:e2e": "playwright test",
    "test:e2e:metamask": "playwright test tests/e2e/metamask.spec.ts",
    "test:e2e:phantom": "playwright test tests/e2e/phantom.spec.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@x3-chain/ts-sdk": "file:../../packages/ts-sdk",
    "@metamask/providers": "^16.0.0",
    "@solana/web3.js": "^1.90.0",
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "dappeteer": "^1.0.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.42.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}
