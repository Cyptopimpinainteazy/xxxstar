# Dockerfile for test runner in containerized environment
FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    git \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml setup.py ./
COPY src ./src
COPY tests ./tests

# Install Python dependencies + testing tools
RUN pip install --no-cache-dir -e . \
    && pip install --no-cache-dir \
    pytest \
    pytest-cov \
    pytest-timeout \
    pytest-xdist \
    requests-mock \
    docker

# Create results directory
RUN mkdir -p /results

WORKDIR /app/tests

# Default command runs all tests with coverage
ENTRYPOINT ["python", "-m", "pytest"]
CMD ["-v", "--tb=short", "--cov=cross_chain_gpu_validator", "--cov-report=html:/results/coverage", "--cov-report=term"]
