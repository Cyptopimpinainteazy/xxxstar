#!/usr/bin/env bash
set -euo pipefail

SELF_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
HOST_KOMPILE="$(command -v kompile || true)"

if [[ -n "$HOST_KOMPILE" ]]; then
  HOST_KOMPILE_PATH="$(readlink -f "$HOST_KOMPILE" 2>/dev/null || realpath "$HOST_KOMPILE")"
  if [[ "$HOST_KOMPILE_PATH" != "$SELF_PATH" ]]; then
    exec "$HOST_KOMPILE" "$@"
  fi
fi

if [[ -x "./tools/k/bin/kompile" ]]; then
  exec ./tools/k/bin/kompile "$@"
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "kompile unavailable: neither host kompile, local tools/k/bin/kompile, nor docker found" >&2
  exit 127
fi

workspace="${PWD}"
exec docker run --rm \
  -u "$(id -u):$(id -g)" \
  -v "$workspace":/work \
  -w /work \
  runtimeverificationinc/kframework-k:ubuntu-jammy-7.1.320 \
  /bin/sh -lc 'kompile "$@"' _ "$@"
