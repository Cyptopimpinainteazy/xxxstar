# Shared Main Chain environment contract for all apps
# Copy relevant keys into each app's .env.local/.env as needed.

# Core chain endpoints
NEXT_PUBLIC_CHAIN_RPC=wss://ws.x3star.net/ws
NEXT_PUBLIC_EVM_RPC=https://rpc.x3star.net/rpc
NEXT_PUBLIC_CHAIN_ID=x3-mainnet
NEXT_PUBLIC_NETWORK_NAME=X3 Chain Mainnet

# Vite-equivalent chain endpoints
VITE_X3_RPC_HTTP=https://rpc.x3star.net/rpc
VITE_RPC_WS=wss://ws.x3star.net/ws
VITE_X3_WS=wss://ws.x3star.net/ws
VITE_X3_API_URL=https://api.x3star.net
VITE_API_BASE_URL=https://api.x3star.net

# Optional service URLs (fall back to VITE_X3_API_URL where supported)
VITE_REGISTRY_URL=https://api.x3star.net
VITE_BRIDGE_URL=https://api.x3star.net
VITE_RPC_PROXY_URL=https://api.x3star.net
VITE_ADMIN_URL=https://api.x3star.net
VITE_CHAIN_DB_URL=https://api.x3star.net
