#!/usr/bin/env python3
"""
GPU Swarm Command-Line Interface (SwarmCLI)
Production operator tools for managing GPU Swarm deployment
"""

import os
import sys
import json
import argparse
import logging
from typing import Dict, Any, Optional, List
from dataclasses import asdict
from datetime import datetime, timedelta
import requests
from tabulate import tabulate

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s'
)
logger = logging.getLogger(__name__)


class SwarmCLI:
    """Main CLI interface for GPU Swarm"""

    def __init__(self, api_url: str = None):
        self.api_url = api_url or os.getenv("SWARM_API_URL", "http://localhost:9000/api")
        self.session = requests.Session()

    def _request(self, method: str, endpoint: str, **kwargs) -> Dict[str, Any]:
        """Make HTTP request to Swarm API"""
        url = f"{self.api_url}/{endpoint.lstrip('/')}"
        try:
            response = self.session.request(method, url, **kwargs)
            response.raise_for_status()
            return response.json() if response.content else {}
        except requests.RequestException as e:
            logger.error(f"API request failed: {e}")
            raise

    # Task Management Commands
    def list_tasks(self, status: str = None, limit: int = 20) -> List[Dict[str, Any]]:
        """List tasks, optionally filtered by status"""
        params = {"limit": limit}
        if status:
            params["status"] = status
        
        response = self._request("GET", "tasks", params=params)
        return response.get("tasks", [])

    def get_task(self, task_id: str) -> Dict[str, Any]:
        """Get detailed task information"""
        return self._request("GET", f"tasks/{task_id}")

    def submit_task(
        self,
        code: str,
        backend: str = "auto",
        priority: int = 0,
        timeout: int = 300
    ) -> str:
        """Submit new task for execution"""
        payload = {
            "code": code,
            "backend": backend,
            "priority": priority,
            "timeout": timeout,
        }
        response = self._request("POST", "tasks", json=payload)
        return response.get("task_id")

    def cancel_task(self, task_id: str) -> bool:
        """Cancel running task"""
        self._request("POST", f"tasks/{task_id}/cancel")
        return True

    # Node Management Commands
    def list_nodes(self, online: bool = True) -> List[Dict[str, Any]]:
        """List GPU nodes"""
        params = {"online": online}
        response = self._request("GET", "nodes", params=params)
        return response.get("nodes", [])

    def get_node(self, node_id: str) -> Dict[str, Any]:
        """Get node details and metrics"""
        return self._request("GET", f"nodes/{node_id}")

    def drain_node(self, node_id: str) -> bool:
        """Gracefully drain node (stop accepting new tasks)"""
        self._request("POST", f"nodes/{node_id}/drain")
        return True

    def reboot_node(self, node_id: str, force: bool = False) -> bool:
        """Reboot GPU node"""
        payload = {"force": force}
        self._request("POST", f"nodes/{node_id}/reboot", json=payload)
        return True

    # Metrics & Monitoring
    def get_cluster_status(self) -> Dict[str, Any]:
        """Get overall cluster health"""
        return self._request("GET", "status")

    def get_metrics(self, metric: str = None, hours: int = 24) -> Dict[str, Any]:
        """Get metrics for specified timeframe"""
        params = {"hours": hours}
        if metric:
            params["metric"] = metric
        return self._request("GET", "metrics", params=params)

    def get_gpu_stats(self) -> Dict[str, Any]:
        """Get GPU utilization statistics"""
        return self._request("GET", "metrics/gpu")

    # Rewards & Economics
    def get_account_balance(self, address: str) -> float:
        """Get account token balance"""
        response = self._request("GET", f"accounts/{address}/balance")
        return response.get("balance", 0.0)

    def get_rewards_history(self, address: str, days: int = 7) -> List[Dict[str, Any]]:
        """Get reward history for address"""
        response = self._request("GET", f"accounts/{address}/rewards",
                                params={"days": days})
        return response.get("rewards", [])

    # Jury & Verification
    def get_verification_status(self, task_id: str) -> Dict[str, Any]:
        """Get verification consensus status"""
        return self._request("GET", f"tasks/{task_id}/verification")

    def get_jury_stats(self) -> Dict[str, Any]:
        """Get jury system statistics"""
        return self._request("GET", "jury/stats")

    # Configuration & Admin
    def get_config(self) -> Dict[str, Any]:
        """Get swarm configuration"""
        return self._request("GET", "config")

    def update_config(self, config: Dict[str, Any]) -> bool:
        """Update swarm configuration (admin only)"""
        self._request("PUT", "config", json=config)
        return True


def create_cli_parser() -> argparse.ArgumentParser:
    """Create argument parser for SwarmCLI"""
    parser = argparse.ArgumentParser(
        description="GPU Swarm Command-Line Interface",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s tasks list
  %(prog)s nodes status
  %(prog)s metrics gpu --hours 24
  %(prog)s task submit --code ./contract.x3 --backend cuda
        """
    )

    parser.add_argument("--api-url", default=os.getenv("SWARM_API_URL", "http://localhost:9000/api"),
                       help="Swarm API URL")
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")
    parser.add_argument("-o", "--output", choices=["text", "json"], default="text",
                       help="Output format")

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # Task commands
    tasks_parser = subparsers.add_parser("tasks", help="Task management")
    tasks_subparsers = tasks_parser.add_subparsers(dest="subcommand")

    list_parser = tasks_subparsers.add_parser("list", help="List tasks")
    list_parser.add_argument("--status", help="Filter by status")
    list_parser.add_argument("--limit", type=int, default=20, help="Max results")

    get_parser = tasks_subparsers.add_parser("get", help="Get task details")
    get_parser.add_argument("task_id", help="Task ID")

    submit_parser = tasks_subparsers.add_parser("submit", help="Submit task")
    submit_parser.add_argument("--code", required=True, help="Code file or inline")
    submit_parser.add_argument("--backend", default="auto", help="GPU backend")
    submit_parser.add_argument("--priority", type=int, default=0, help="Priority")
    submit_parser.add_argument("--timeout", type=int, default=300, help="Timeout seconds")

    cancel_parser = tasks_subparsers.add_parser("cancel", help="Cancel task")
    cancel_parser.add_argument("task_id", help="Task ID to cancel")

    # Node commands
    nodes_parser = subparsers.add_parser("nodes", help="Node management")
    nodes_subparsers = nodes_parser.add_subparsers(dest="subcommand")

    nodes_list = nodes_subparsers.add_parser("list", help="List nodes")
    nodes_list.add_argument("--all", action="store_true", help="Include offline nodes")

    nodes_get = nodes_subparsers.add_parser("get", help="Get node details")
    nodes_get.add_argument("node_id", help="Node ID")

    drain_parser = nodes_subparsers.add_parser("drain", help="Drain node")
    drain_parser.add_argument("node_id", help="Node ID")

    reboot_parser = nodes_subparsers.add_parser("reboot", help="Reboot node")
    reboot_parser.add_argument("node_id", help="Node ID")
    reboot_parser.add_argument("--force", action="store_true", help="Force reboot")

    # Metrics commands
    metrics_parser = subparsers.add_parser("metrics", help="View metrics")
    metrics_subparsers = metrics_parser.add_subparsers(dest="subcommand")

    status_parser = metrics_subparsers.add_parser("status", help="Cluster status")

    gpu_parser = metrics_subparsers.add_parser("gpu", help="GPU statistics")
    gpu_parser.add_argument("--hours", type=int, default=24, help="Hours to retrieve")

    # Account commands
    account_parser = subparsers.add_parser("account", help="Account management")
    account_subparsers = account_parser.add_subparsers(dest="subcommand")

    balance_parser = account_subparsers.add_parser("balance", help="Get balance")
    balance_parser.add_argument("address", help="Account address")

    rewards_parser = account_subparsers.add_parser("rewards", help="Get rewards")
    rewards_parser.add_argument("address", help="Account address")
    rewards_parser.add_argument("--days", type=int, default=7, help="Days of history")

    # Jury commands
    jury_parser = subparsers.add_parser("jury", help="Jury system")
    jury_subparsers = jury_parser.add_subparsers(dest="subcommand")

    jury_stats = jury_subparsers.add_parser("stats", help="Get jury statistics")

    jury_verify = jury_subparsers.add_parser("verify", help="Check verification status")
    jury_verify.add_argument("task_id", help="Task ID")

    return parser


def main():
    """Main CLI entrypoint"""
    parser = create_cli_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    # Initialize CLI
    cli = SwarmCLI(api_url=args.api_url)

    try:
        if args.command == "tasks":
            if args.subcommand == "list":
                tasks = cli.list_tasks(status=args.status, limit=args.limit)
                if args.output == "json":
                    print(json.dumps(tasks, indent=2))
                else:
                    print(tabulate(tasks, headers="keys", tablefmt="grid"))

            elif args.subcommand == "get":
                task = cli.get_task(args.task_id)
                if args.output == "json":
                    print(json.dumps(task, indent=2))
                else:
                    for key, value in task.items():
                        print(f"{key}: {value}")

            elif args.subcommand == "submit":
                with open(args.code) as f:
                    code = f.read()
                task_id = cli.submit_task(code, args.backend, args.priority, args.timeout)
                print(f"✓ Task submitted: {task_id}")

            elif args.subcommand == "cancel":
                cli.cancel_task(args.task_id)
                print(f"✓ Task {args.task_id} cancelled")

        elif args.command == "nodes":
            if args.subcommand == "list":
                nodes = cli.list_nodes(online=not args.all)
                if args.output == "json":
                    print(json.dumps(nodes, indent=2))
                else:
                    print(tabulate(nodes, headers="keys", tablefmt="grid"))

            elif args.subcommand == "get":
                node = cli.get_node(args.node_id)
                if args.output == "json":
                    print(json.dumps(node, indent=2))
                else:
                    for key, value in node.items():
                        print(f"{key}: {value}")

            elif args.subcommand == "drain":
                cli.drain_node(args.node_id)
                print(f"✓ Node {args.node_id} drained")

            elif args.subcommand == "reboot":
                cli.reboot_node(args.node_id, force=args.force)
                print(f"✓ Node {args.node_id} rebooting")

        elif args.command == "metrics":
            if args.subcommand == "status":
                status = cli.get_cluster_status()
                if args.output == "json":
                    print(json.dumps(status, indent=2))
                else:
                    print("Cluster Status")
                    print("=" * 50)
                    for key, value in status.items():
                        print(f"{key}: {value}")

            elif args.subcommand == "gpu":
                gpu_stats = cli.get_gpu_stats()
                if args.output == "json":
                    print(json.dumps(gpu_stats, indent=2))
                else:
                    print("GPU Statistics")
                    print("=" * 50)
                    for key, value in gpu_stats.items():
                        print(f"{key}: {value}")

        elif args.command == "account":
            if args.subcommand == "balance":
                balance = cli.get_account_balance(args.address)
                print(f"Balance: {balance} X3")

            elif args.subcommand == "rewards":
                rewards = cli.get_rewards_history(args.address, args.days)
                if args.output == "json":
                    print(json.dumps(rewards, indent=2))
                else:
                    print(tabulate(rewards, headers="keys", tablefmt="grid"))

        elif args.command == "jury":
            if args.subcommand == "stats":
                stats = cli.get_jury_stats()
                if args.output == "json":
                    print(json.dumps(stats, indent=2))
                else:
                    print("Jury System Statistics")
                    print("=" * 50)
                    for key, value in stats.items():
                        print(f"{key}: {value}")

            elif args.subcommand == "verify":
                verification = cli.get_verification_status(args.task_id)
                if args.output == "json":
                    print(json.dumps(verification, indent=2))
                else:
                    print(f"Verification Status for {args.task_id}")
                    print("=" * 50)
                    for key, value in verification.items():
                        print(f"{key}: {value}")

    except KeyboardInterrupt:
        print("\nInterrupted")
        sys.exit(1)
    except Exception as e:
        logger.error(f"Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
