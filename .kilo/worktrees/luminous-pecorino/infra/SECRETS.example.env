# X3 Chain Secrets Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Blockchain Infrastructure
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
DUNE_API_KEY=YOUR_DUNE_API_KEY
COINGECKO_API_KEY=YOUR_COINGECKO_API_KEY
GOPLUS_API_KEY=YOUR_GOPLUS_API_KEY

# RPC Services
ETHEREUM_RPC_KEY=YOUR_ETHEREUM_RPC_KEY
SOLANA_RPC_KEY=YOUR_SOLANA_RPC_KEY

# Mainnet RPC Endpoints (DRPC - Configured)
SOLANA_MAINNET_WSS=wss://lb.drpc.live/solana/ArgUBy0RzURpos-Jlz1TqLRxbgscV2AR8JXZrqRhf0fE
SOLANA_MAINNET_HTTPS=https://lb.drpc.live/solana/ArgUBy0RzURpos-Jlz1TqLRxbgscV2AR8JXZrqRhf0fE

# Wallet and Security
WALLET_MASTER_KEYSTORE_PATH=YOUR_WALLET_KEYSTORE_PATH
WALLET_MASTER_PASSWORD=YOUR_WALLET_PASSWORD
NODE_OPERATOR_KEY=YOUR_NODE_OPERATOR_KEY

# Database
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# Git
GIT_SSH_KEY_PATH=YOUR_GIT_SSH_KEY_PATH
GIT_TOKEN=YOUR_GIT_TOKEN

# Advanced Features
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# DEX and Trading
UNISWAP_API_KEY=YOUR_UNISWAP_API_KEY
SUSHISWAP_API_KEY=YOUR_SUSHISWAP_API_KEY
JUPITER_API_KEY=YOUR_JUPITER_API_KEY

# Flash Loans
AAVE_API_KEY=YOUR_AAVE_API_KEY
DYDX_API_KEY=YOUR_DYDX_API_KEY

# MEV and Bridge
MEV_OPERATOR_KEY=YOUR_MEV_OPERATOR_KEY
BRIDGE_OPERATOR_KEY=YOUR_BRIDGE_OPERATOR_KEY
