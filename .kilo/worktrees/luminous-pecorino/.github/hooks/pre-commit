#!/usr/bin/env bash
# ProofForge Pre-Commit Hook
# Runs proof scanning on staged changes before commit
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Directories
REPO_ROOT=$(git rev-parse --show-toplevel)
PROOF_BINARY="${REPO_ROOT}/target/release/x3-proof"

echo -e "${BLUE}╭─ ProofForge Pre-Commit Gate${NC}"
echo -e "${BLUE}│${NC}"

# Check if binary exists, build if needed
if [ ! -f "$PROOF_BINARY" ]; then
    echo -e "${BLUE}│${NC} ${YELLOW}⚠ Binary not found, building...${NC}"
    cd "$REPO_ROOT"
    cargo build -p proof-forge --release 2>&1 | grep -E "Compiling|Finished" || true
    echo -e "${BLUE}│${NC}"
fi

# Get list of changed files
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACMRTU)

# Check if any critical files have changed
CRITICAL_FILES_CHANGED=0
for file in $CHANGED_FILES; do
    if [[ $file == *"pallet"* ]] || [[ $file == *"runtime"* ]] || [[ $file == *"consensus"* ]] || \
       [[ $file == *"bridge"* ]] || [[ $file == *"x3-cross-vm"* ]]; then
        CRITICAL_FILES_CHANGED=1
        break
    fi
done

# Run scan-claims
echo -e "${BLUE}│${NC} Running claim scan..."
SCAN_OUTPUT=$("$PROOF_BINARY" scan-claims 2>&1 || true)
SCAN_STATUS=$?

if [[ $SCAN_OUTPUT == *"Unproven claims"* ]]; then
    echo -e "${YELLOW}│${NC} ${YELLOW}⚠ Found unproven claims${NC}"
    echo -e "${BLUE}│${NC}"
    echo "$SCAN_OUTPUT" | sed 's/^/│ /'
    echo -e "${BLUE}│${NC}"
else
    echo -e "${BLUE}│${NC} ${GREEN}✓ All claims verified${NC}"
    echo -e "${BLUE}│${NC}"
fi

# Run AI patch firewall if critical files changed
if [ $CRITICAL_FILES_CHANGED -eq 1 ]; then
    echo -e "${BLUE}│${NC} Running AI Patch Firewall (critical files changed)..."
    PATCH_OUTPUT=$("$PROOF_BINARY" ai-patch-firewall 2>&1 || true)
    PATCH_STATUS=$?
    
    if [[ $PATCH_OUTPUT == *"No AI-related vulnerabilities"* ]]; then
        echo -e "${BLUE}│${NC} ${GREEN}✓ AI Patch Firewall passed${NC}"
    else
        echo -e "${YELLOW}│${NC} ${YELLOW}⚠ AI Patch Firewall warnings:${NC}"
        echo "$PATCH_OUTPUT" | sed 's/^/│ /'
    fi
    echo -e "${BLUE}│${NC}"
fi

# Show commit message preview
COMMIT_MSG=$(git diff --cached --name-only | xargs -I {} bash -c 'echo "  - {}"' | head -5)
echo -e "${BLUE}│${NC} Staged changes:"
echo "$COMMIT_MSG" | sed 's/^/│ /'
echo -e "${BLUE}│${NC}"

# Final status
if [ $SCAN_STATUS -eq 0 ] || [ $SCAN_STATUS -eq 1 ]; then
    echo -e "${BLUE}╰─ ${GREEN}Pre-Commit Gate: PASSED${NC}"
    exit 0
else
    echo -e "${BLUE}╰─ ${RED}Pre-Commit Gate: BLOCKED${NC}"
    exit 1
fi
