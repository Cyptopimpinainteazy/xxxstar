# Analytics Service Environment Configuration
# Copy to .env and customize for your environment

# Server Configuration
HOST=127.0.0.1
PORT=8080

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/analytics
DATABASE_POOL_SIZE=16

# Logging
RUST_LOG=info,analytics_service=debug

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Optional: API Key for protected endpoints
# API_KEY=your-secret-api-key

# Optional: Metrics export
# METRICS_ENDPOINT=http://prometheus:9090/api/v1/write
