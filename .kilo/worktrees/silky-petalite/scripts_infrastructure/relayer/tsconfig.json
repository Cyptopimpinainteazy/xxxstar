{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["mocha", "node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*.ts", "node_modules", "dist"]
}
