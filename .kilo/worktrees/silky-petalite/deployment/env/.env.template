# Atlas Sphere Environment Configuration
# Copy this to .env and customize for your deployment

# ============================================================================
# Application Settings
# ============================================================================

# Node environment
NODE_ENV=production

# API Configuration
VITE_API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5173

# ============================================================================
# Authentication
# ============================================================================

# IMPORTANT: Change these in production!
AUTH_SALT=atlas-sphere-production-2026
JWT_SECRET=your-secret-key-here-change-this

# Session timeout (milliseconds)
SESSION_TIMEOUT=86400000  # 24 hours

# ============================================================================
# Database / Redis
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Cross-Chain GPU Validator
# ============================================================================

CCGV_LOG_LEVEL=INFO
CCGV_REQUIRE_GPU=false
CCGV_GPU_PARITY_CHECK=false

# RPC Endpoints
CCGV_EVM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
CCGV_SVM_RPC=https://api.mainnet-beta.solana.com
CCGV_COSMOS_RPC=https://lcd-cosmoshub.nolus.io
CCGV_SUBSTRATE_RPC=https://rpc.polkadot.io

# ============================================================================
# Monitoring & Logging
# ============================================================================

LOG_LEVEL=info
LOG_FILE=/var/log/atlas/atlas-sphere.log

# Prometheus metrics
PROMETHEUS_PORT=9090
METRICS_PORT=8001

# ============================================================================
# Security
# ============================================================================

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# IP whitelist (comma-separated, empty = allow all)
IP_WHITELIST=

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_AUTH=true
ENABLE_METRICS=true
ENABLE_DASHBOARD=true
ENABLE_GPU_ACCELERATION=false

# ============================================================================
# Development (only for local development)
# ============================================================================

# Debug mode
DEBUG=false

# Mock RPC for testing
USE_MOCK_RPC=false

# Skip GPU checks
SKIP_GPU_VALIDATION=false
