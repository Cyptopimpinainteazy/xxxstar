node_bin=/usr/local/bin/x3-chain-node
chain_spec=/etc/x3-chain/x3-testnet-raw.json
base_path=/var/lib/x3-chain/x3-lab-val-02
node_name=x3-lab-val-02
validator=true
enable_rpc=false
rpc_bind=private
rpc_port=9944
enable_prometheus=true
prometheus_bind=private
prometheus_port=9615
p2p_port=30333
node_key_file=/var/lib/x3-chain/node-keys/x3-lab-val-02.key
bootnodes=
pruning=archive
database_backend=rocksdb
rpc_cors=
telemetry_url=
extra_args=