{
  "dashboard": {
    "title": "GPU Swarm - GPU Metrics & Performance",
    "tags": ["gpu-swarm", "gpu-metrics"],
    "timezone": "browser",
    "panels": [
      {
        "title": "GPU Utilization by Device",
        "targets": [
          {
            "expr": "gpu_utilization_percent",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "fieldConfig": {
          "defaults": {"unit": "percent"}
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "GPU Temperature",
        "targets": [
          {
            "expr": "gpu_temperature_celsius",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "fieldConfig": {
          "defaults": {"unit": "celsius"}
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Memory Bandwidth Usage",
        "targets": [
          {
            "expr": "rate(gpu_memory_bandwidth_bytes[5m]) / 1024 / 1024",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "fieldConfig": {
          "defaults": {"unit": "MBps"}
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "Power Consumption",
        "targets": [
          {
            "expr": "gpu_power_consumption_watts",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "fieldConfig": {
          "defaults": {"unit": "watt"}
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "title": "Thermal Throttling Events",
        "targets": [
          {
            "expr": "increase(gpu_thermal_throttle_events_total[5m])",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "title": "GPU Error Count",
        "targets": [
          {
            "expr": "increase(gpu_error_count_total[5m])",
            "legendFormat": "{{ device }}",
            "refId": "A"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 1
  }
}
