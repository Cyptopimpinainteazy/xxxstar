# X3 Chain public RPC (HTTP + WS) — basic-auth gated
#
# Goal: expose JSON-RPC publicly but require HTTP Basic Auth.
# Note: Basic Auth credentials are sent on every request. Always use TLS.
#
# Assumptions:
# - Node RPC bound to localhost:9944 (recommended)
# - nginx terminates TLS and handles rate limiting + authentication
#
# Setup:
# - Create htpasswd file:
#     sudo apt-get install apache2-utils
#     sudo htpasswd -c /etc/nginx/.htpasswd x3
#
# Copy into /etc/nginx/sites-available/x3-chain-rpc and enable.

map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

# Basic rate limiting (tune per your capacity)
limit_req_zone $binary_remote_addr zone=rpc_rps:10m rate=10r/s;
limit_conn_zone $binary_remote_addr zone=rpc_conns:10m;

upstream x3_rpc_upstream {
  server 127.0.0.1:9944;
  keepalive 64;
}

server {
  listen 443 ssl http2;
  server_name rpc.testnet.x3;

  # TLS config omitted (use certbot or your preferred method)

  # Avoid oversized JSON-RPC bodies (keep in sync with node --rpc-max-request-size)
  client_max_body_size 10m;

  auth_basic "X3 Chain RPC";
  auth_basic_user_file /etc/nginx/.htpasswd;

  # Connection limiting
  limit_conn rpc_conns 25;

  location / {
    # RPC is JSON-RPC over HTTP (POST) and WS upgrade (GET).
    limit_except GET POST { deny all; }

    limit_req zone=rpc_rps burst=100 nodelay;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # WebSocket upgrade
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    # Timeouts (WS subscriptions can be long-lived)
    proxy_connect_timeout 5s;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    proxy_buffering off;

    proxy_pass http://x3_rpc_upstream;
  }
}
